rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile media: users/{uid}/avatar.jpg and users/{uid}/cover.jpg.
    // Any signed-in user may read; only the owner may write their own files.
    match /users/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Task media: tasks/{taskId}/attachments/{id}.<ext> (images & videos —
    // proof, references). `{allPaths=**}` covers the nested attachments
    // folder.
    //
    // M3 fix (2026-07-03): task evidence is CREATE-ONLY. Every client upload
    // already mints a guaranteed-unique Firestore push id for its path
    // (`uploadAttachment`), so overwrite/delete have no legitimate caller —
    // denying them makes every proof photo IMMUTABLE from the moment it is
    // uploaded (a strictly stronger guarantee than "immutable once
    // approved": review decisions always look at exactly what was
    // submitted). A rework loop uploads NEW files; the old evidence stays.
    // Storage rules can't read the task doc to scope reads/creates by
    // assignee/branch — the meaningful attach gate remains the Firestore
    // write of the URL onto the task (firestore.rules), and task ids are
    // unguessable 20-char auto-ids.
    match /tasks/{taskId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Case media: cases/{caseId}/attachments/{id}.<ext> (Case Management).
    // CREATE-ONLY, mirroring task evidence (M3): every upload mints a unique
    // Firestore push id for its path, so overwrite/delete have no legitimate
    // caller — a case's attached evidence is immutable from upload. The
    // meaningful attach gate is the Firestore write of the URL onto the case
    // message (firestore.rules); case ids are unguessable 20-char auto-ids.
    match /cases/{caseId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Request media: requests/{requestId}/attachments/{id}.<ext> (Operations
    // Requests). CREATE-ONLY, mirroring task/case evidence (M3): every upload
    // mints a unique Firestore push id for its path, so overwrite/delete have no
    // legitimate caller — a request's attached media is immutable from upload.
    // The meaningful attach gate is the Firestore write of the URL onto the
    // request / its event (firestore.rules); request ids are unguessable 20-char
    // auto-ids.
    match /requests/{requestId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Event media (Community Hub): events/{eventId}/hero.<ext>. Unlike task /
    // case / request evidence, the hero image is a single, replaceable cover at a
    // fixed filename, so write (create + overwrite) is allowed — mirroring the
    // branch-logo pattern. Any signed-in user may read (covers appear on the hub
    // for every role); the meaningful gate is the Firestore write of the URL onto
    // events/{id} (firestore.rules) — admin / own-branch manager only — so a
    // non-editor upload can never be attached to an event.
    match /events/{eventId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Branch media (§8): branches/{branchId}/logo.jpg and cover.jpg. Any
    // signed-in user may read (logos appear on schedules / dashboards for every
    // role). Write is left to any signed-in user here because Storage rules
    // can't cheaply read the caller's role; the meaningful gate is the Firestore
    // write of the URL onto branches/{id} (firestore.rules) — admin-only — so a
    // non-admin upload can never be attached to a branch.
    match /branches/{branchId}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
