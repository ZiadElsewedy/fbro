rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile media: users/{uid}/avatar.jpg and users/{uid}/cover.jpg.
    // Any signed-in user may read; only the owner may write their own files.
    match /users/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Task media: tasks/{taskId}/proof.jpg (legacy) and
    // tasks/{taskId}/attachments/{id}.<ext> (Phase 10 — images & videos).
    // `{allPaths=**}` covers the nested attachments folder. Any signed-in user
    // may read/write. Storage rules can't read the task doc to scope by
    // assignee/branch, so the meaningful gate is the Firestore write of the
    // attachment URL onto the task event (firestore.rules) — only the assigned
    // employee or an own-branch manager/admin can attach it to the task.
    match /tasks/{taskId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
