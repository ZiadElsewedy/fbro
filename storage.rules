rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Profile media: users/{uid}/avatar.jpg and users/{uid}/cover.jpg.
    // Any signed-in user may read; only the owner may write their own files.
    match /users/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Task proof images: tasks/{taskId}/proof.jpg.
    // Any signed-in user may read/write. Storage rules can't read the task doc
    // to scope by assignee/branch, so the meaningful gate is the Firestore
    // `tasks/{taskId}.proofImageUrl` write (firestore.rules) — only the assigned
    // employee or an own-branch manager/admin can attach the URL to the task.
    match /tasks/{taskId}/{file} {
      allow read, write: if request.auth != null;
    }
  }
}
