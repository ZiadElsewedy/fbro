rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // The signed-in user's own document — their role/branch live here. Firestore
    // caches this get() per request, so repeated calls bill a single read.
    function selfDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function selfRole()   { return isSignedIn() ? selfDoc().get('role', 'employee') : 'none'; }
    function selfBranch() { return selfDoc().get('branchId', ''); }

    function isAdmin()   { return isSignedIn() && selfRole() == 'admin'; }
    function isManager() { return isSignedIn() && selfRole() == 'manager'; }

    // Branch scoping. Admin is global (any branch); a manager reaches only their
    // own branch. Employees never reach a whole branch — only their own data.
    function canReachBranch(branch) {
      return isAdmin() || (isManager() && branch == selfBranch());
    }

    // ── Users ──────────────────────────────────────────────────────
    // Self: read own doc + limited self-update (cannot touch privileged fields,
    //   but may write non-privileged fields like the FCM token).
    // Branch members: read users in their OWN branch — their team. Managers see
    //   their team; employees (Phase 7) see the coworkers on their shift + their
    //   manager (the weekly schedule stores uids, resolved to names here). Read
    //   only — only an admin writes user accounts.
    // Admin: read/write everything — approvals, promotions, branch moves,
    //   (de)activation. **Account approval is admin-only (Phase 6).**
    match /users/{uid} {
      allow read: if isOwner(uid)
        || isAdmin()
        || (selfBranch() != ''
            && resource.data.get('branchId', '') == selfBranch());

      // Self-registration only — always as a PENDING, INACTIVE employee. A new
      // account cannot use the app until an ADMIN approves it (update below).
      // Promotion to manager/admin, branch assignment and activation are never
      // self-service.
      allow create: if isOwner(uid)
        && request.resource.data.get('role', 'employee') == 'employee'
        && request.resource.data.get('isActive', false) == false
        && request.resource.data.get('approvalStatus', 'pending') == 'pending';

      // Admin: full control — approve/reject, promote, move branch, (de)activate.
      // Self: profile-only updates — all privileged fields stay frozen (role,
      //   isActive, branchId, assignedShift, approvalStatus). Non-privileged
      //   fields (profile data, fcmToken) are free to change.
      // Managers do NOT write user docs (they manage branch operations only).
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.get('role', 'employee')
                 == resource.data.get('role', 'employee')
            && request.resource.data.get('isActive', true)
                 == resource.data.get('isActive', true)
            && request.resource.data.get('branchId', '')
                 == resource.data.get('branchId', '')
            && request.resource.data.get('assignedShift', '')
                 == resource.data.get('assignedShift', '')
            && request.resource.data.get('approvalStatus', 'approved')
                 == resource.data.get('approvalStatus', 'approved'));

      // Deactivate via isActive (an admin update), never a hard delete; document
      // cleanup on account removal belongs to a Cloud Function.
      allow delete: if false;
    }

    // ── Tasks (Phase 3, +Phase 9 multi-assignee) ───────────────────
    // Branch-scoped: admin = all branches; manager = own branch; employee =
    // tasks they're assigned to. A task carries `branchId` (owning branch) and
    // `assigneeIds` (the assignees — Phase 9; `assignedEmployeeId` mirrors the
    // primary assignee for backward compatibility).
    //   read   — admin/own-branch manager, OR any assigned employee.
    //   create/delete — admin/own-branch manager only.
    //   update — admin/own-branch manager (full edit, incl. approve/reject), OR
    //            an assigned employee on a task they're assigned to, with limits:
    //            they may NOT reassign (assigneeIds frozen), move branch, change
    //            the creator, or set the terminal approved/rejected status
    //            (review stays manager/admin). They MAY tick checklist items,
    //            add notes/proof, and advance status up to waitingReview.
    function isTaskAssignee() {
      return request.auth.uid in resource.data.get('assigneeIds', [])
        || resource.data.get('assignedEmployeeId', '') == request.auth.uid;
    }
    match /tasks/{taskId} {
      allow read: if canReachBranch(resource.data.get('branchId', ''))
        || isTaskAssignee();

      allow create: if canReachBranch(request.resource.data.get('branchId', ''));

      allow update: if canReachBranch(resource.data.get('branchId', ''))
        || (isTaskAssignee()
            // employees can't reassign the task (assignees frozen)
            && request.resource.data.get('assigneeIds', [])
                 == resource.data.get('assigneeIds', [])
            && request.resource.data.get('branchId', '')
                 == resource.data.get('branchId', '')
            && request.resource.data.get('createdBy', '')
                 == resource.data.get('createdBy', '')
            && request.resource.data.get('status', 'pending') != 'approved'
            && request.resource.data.get('status', 'pending') != 'rejected'
            // employees can't forge review attribution
            && request.resource.data.get('approvedBy', '')
                 == resource.data.get('approvedBy', '')
            && request.resource.data.get('rejectedBy', '')
                 == resource.data.get('rejectedBy', ''));

      allow delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Task templates (stabilization) ─────────────────────────────
    // Reusable task blueprints ("Open Shop", "Night Checklist", …) managed by
    // managers/admins. A template carries a `branchId` (owning branch) or '' for
    // a GLOBAL template (admin-made, usable by every branch). Employees never
    // need templates.
    //   read   — any admin or manager (branch filtering is applied client-side;
    //            the collection is tiny, so a full read is acceptable and a
    //            collection query stays provably safe under this rule).
    //   create — admin (any branch / global), OR an own-branch manager.
    //   update/delete — admin, OR the owning-branch manager.
    match /task_templates/{templateId} {
      allow read: if isAdmin() || isManager();
      allow create: if isAdmin()
        || (isManager()
            && request.resource.data.get('branchId', '') == selfBranch());
      allow update, delete: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());
    }

    // ── Branches (Phase 5) ─────────────────────────────────────────
    // Any signed-in user may READ branches (names are shown in pickers and on
    // cards across roles). Only an admin may create/edit. "Delete" is a soft
    // delete (an admin update setting `deletedAt`), so hard deletes are denied.
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Weekly schedules (Phase 7) ─────────────────────────────────
    // The in-app weekly roster, one doc per (branch, week). Branch-scoped:
    //   read   — admin/own-branch manager, OR any employee of that branch (so
    //            they can see their own schedule + today's team).
    //   write  — admin/own-branch manager only (employees never edit; swaps are
    //            applied by the manager on approval).
    match /weekly_schedules/{scheduleId} {
      // `resource == null` first: a `get()` on a not-yet-created week's doc must
      // return an empty snapshot (no schedule), not a permission error — the app
      // reads a deterministic week id that often doesn't exist yet. For existing
      // docs, scope by branch (admin/own-branch manager, or any branch employee).
      allow read: if resource == null
        || canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('branchId', '') == selfBranch();
      allow create: if canReachBranch(request.resource.data.get('branchId', ''));
      allow update, delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Shift swaps (Phase 7) ──────────────────────────────────────
    // A swap request between two employees, approved by the branch manager.
    //   read   — admin/own-branch manager, OR the requester/target employee.
    //   create — the requester themself, for a swap in their own branch, only for
    //            an UPCOMING shift (past/in-progress shifts can't be swapped —
    //            spec §2; the precise rule also lives client-side in
    //            SwapEligibility, this is the server backstop).
    //   update — admin/own-branch manager (approve/reject), OR either involved
    //            employee (coworker approve / requester cancel / decline). The
    //            exact status flow is validated client-side (ShiftSwapCubit).
    //   delete — admin/own-branch manager only.

    // Day offset within the week (Sunday=0 … Saturday=6), matching ScheduleDay.
    function swapDayOffset(d) {
      return d == 'monday' ? 1
        : d == 'tuesday' ? 2
        : d == 'wednesday' ? 3
        : d == 'thursday' ? 4
        : d == 'friday' ? 5
        : d == 'saturday' ? 6
        : 0; // sunday / unknown
    }
    // Shift start, minutes past midnight (mirrors SwapEligibility / timeRange):
    // morning 08:30, night 16:30.
    function swapShiftMinutes(s) {
      return s == 'night' ? (16 * 60 + 30) : (8 * 60 + 30);
    }
    // The slot's start instant must be strictly after the request time. weekStart
    // is the week's Sunday 00:00 (a Timestamp).
    function swapSlotInFuture(data) {
      return data.weekStart
          + duration.value(swapDayOffset(data.get('day', 'sunday')), 'd')
          + duration.value(swapShiftMinutes(data.get('shift', 'morning')), 'm')
        > request.time;
    }
    match /shift_swaps/{swapId} {
      allow read: if canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('requesterId', '') == request.auth.uid
        || resource.data.get('targetId', '') == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.get('requesterId', '') == request.auth.uid
        && request.resource.data.get('branchId', '') == selfBranch()
        && swapSlotInFuture(request.resource.data);
      allow update: if canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('requesterId', '') == request.auth.uid
        || resource.data.get('targetId', '') == request.auth.uid;
      allow delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Broadcasts (Communications Center — Phase 1 + Phase 2 engine) ──
    // A one-way announcement to every branch, a single branch, or one individual.
    // The targeting dimension for the branch/all feed is `branchId`: a branch id
    // scopes it to that branch; the empty string '' means ALL branches. A direct
    // message to one user carries `targetUserId` + a non-branch `branchId` marker
    // ('__direct__'), so it never surfaces in a branch/all feed.
    //
    //   read   — admin (all), OR the individual recipient (`targetUserId`), OR a
    //            branch member of a branch/all-branches broadcast (a non-DM doc
    //            whose branchId is '' or their own branch). A branch member's
    //            `whereIn: [selfBranch, '']` query is provably safe under this.
    //   write  — OWNED BY THE `sendBroadcast` Cloud Function (Admin SDK, which
    //            bypasses these rules). Clients never write broadcast docs
    //            directly — the function validates sender permissions, resolves
    //            recipients, persists the doc, and pushes the notification.
    match /broadcasts/{broadcastId} {
      allow read: if isAdmin()
        || resource.data.get('targetUserId', '') == request.auth.uid
        || request.auth.uid in resource.data.get('targetUserIds', [])
        || (resource.data.get('targetUserId', '') == ''
            && resource.data.get('targetUserIds', []).size() == 0
            && (resource.data.get('branchId', '') == ''
                || resource.data.get('branchId', '') == selfBranch()));

      // Content + delivery stats are owned by the `sendBroadcast` Cloud Function
      // (Admin SDK, bypasses rules). Clients may flip ONLY `archivedAt` (archive
      // / unarchive) — and only an admin, the owning-branch manager, or the
      // original sender. The field-diff freezes every other field, so delivery
      // stats / recipients can never be forged client-side.
      allow update: if request.resource.data
              .diff(resource.data).affectedKeys()
              .hasOnly(['archivedAt'])
        && (isAdmin()
            || resource.data.get('senderId', '') == request.auth.uid
            || canReachBranch(resource.data.get('branchId', '')));

      allow create, delete: if false;
    }

    // ── Broadcast templates (Communications Center — Phase 2 Commit 2) ──
    // Reusable broadcast blueprints (mirrors `task_templates`). A template
    // carries a `branchId` (owning branch) or '' for a GLOBAL template
    // (admin-made, usable by every branch). Employees never need templates.
    //   read   — any admin or manager (branch filtering is client-side).
    //   create — admin (any/global), OR an own-branch manager.
    //   update/delete — admin, OR the owning-branch manager.
    match /broadcastTemplates/{templateId} {
      allow read: if isAdmin() || isManager();
      allow create: if isAdmin()
        || (isManager()
            && request.resource.data.get('branchId', '') == selfBranch());
      allow update, delete: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());
    }

    // ── Broadcast schedules (Communications Center — Phase 2 Commit 4) ──
    // Scheduled / recurring broadcasts. The `runBroadcastSchedules` Cloud
    // Function fires + advances them via the Admin SDK (bypasses these rules);
    // clients only manage their own.
    //   read   — admin, OR the creator (`senderId`).
    //   create — the creator themself; a manager only for their own branch.
    //   update/delete — admin, OR the creator (pause/resume/edit/cancel).
    match /broadcastSchedules/{scheduleId} {
      allow read: if isAdmin()
        || resource.data.get('senderId', '') == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.get('senderId', '') == request.auth.uid
        && (isAdmin()
            || (isManager()
                && (request.resource.data.get('branchId', '') == selfBranch()
                    || request.resource.data.get('branchId', '') == '')));
      allow update, delete: if isAdmin()
        || resource.data.get('senderId', '') == request.auth.uid;
    }

    // ── Task reminders ledger (Communications Center — Phase 2 Commit 5) ──
    // Per-task anti-spam bookkeeping written ONLY by the `runTaskReminders` Cloud
    // Function (Admin SDK, bypasses rules). Clients never write it; an admin may
    // read it for diagnostics.
    match /taskReminders/{taskId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Reminder config (Communications Center — Phase 2 Commit 5) ──
    // Org-wide reminder rules (enabled · quiet hours · max reminders), read by the
    // scheduler. Admin-managed; any admin/manager may read.
    match /reminderConfig/{id} {
      allow read: if isAdmin() || isManager();
      allow write: if isAdmin();
    }

    // ── Notifications (Notification System Phase 1) ────────────────
    // One in-app notification doc per recipient (`notifications/{id}`). Task
    // events are written by the client (`NotifyTaskEvent`); broadcast
    // notifications are written by the `sendBroadcast` Cloud Function (Admin SDK,
    // which bypasses these rules).
    //   read   — the recipient, or an admin.
    //   create — any signed-in user, who must stamp themselves as `senderUid`
    //            (internal-tool trust model, consistent with task-doc writes).
    //   update — the recipient only (mark read flips `readAt`); content is not
    //            re-validated, but only the owner can touch their own docs.
    //   delete — the recipient, or an admin (dismiss / cleanup).
    match /notifications/{id} {
      allow read: if isOwner(resource.data.get('recipientUid', '')) || isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.get('senderUid', '') == request.auth.uid;
      allow update: if isOwner(resource.data.get('recipientUid', ''));
      allow delete: if isOwner(resource.data.get('recipientUid', '')) || isAdmin();
    }
  }
}
