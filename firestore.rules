rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // The signed-in user's own document — their role/branch live here. Firestore
    // caches this get() per request, so repeated calls bill a single read.
    function selfDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function selfRole()   { return isSignedIn() ? selfDoc().get('role', 'employee') : 'none'; }
    function selfBranch() { return selfDoc().get('branchId', ''); }

    function isAdmin()   { return isSignedIn() && selfRole() == 'admin'; }
    function isManager() { return isSignedIn() && selfRole() == 'manager'; }

    // Branch scoping. Admin is global (any branch); a manager reaches only their
    // own branch. Employees never reach a whole branch — only their own data.
    function canReachBranch(branch) {
      return isAdmin() || (isManager() && branch == selfBranch());
    }

    // Case Management: the reporter's uid is NOT on the case doc (privacy split
    // — it lives in the private `cases/{id}/reporter/identity` subdoc, readable
    // only by the reporter + an admin). This resolves whether the caller is the
    // reporter of [caseId], for the owner's own-case reads + message writes. Two
    // reads (exists + get); Firestore caches per request. Only used on
    // SINGLE-doc gets — the manager/admin list queries are proven safe by the
    // pure `visibleToManager` field check, never this get().
    function isCaseReporter(caseId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/cases/$(caseId)/reporter/identity)
        && get(/databases/$(database)/documents/cases/$(caseId)/reporter/identity)
             .data.get('createdByUserId', '') == request.auth.uid;
    }

    // The case doc's data (status / branch / visibility), used by the `messages`
    // subcollection rules to gate on the parent. Firestore caches this get()
    // per request, so repeated calls within one evaluation bill a single read.
    function caseData(caseId) {
      return get(/databases/$(database)/documents/cases/$(caseId)).data;
    }

    // The request doc's data (status / branch / requester / policy), used by the
    // `events` subcollection rules to gate on the parent. Cached per request.
    function requestData(requestId) {
      return get(/databases/$(database)/documents/requests/$(requestId)).data;
    }

    // ── Users ──────────────────────────────────────────────────────
    // DROP is ADMIN-PROVISIONED — there is no public registration. Accounts are
    // created server-side by the `createUserAccount` Cloud Function (Admin SDK,
    // which bypasses these rules), so clients can NEVER create a user document.
    // Self: read own doc + limited self-update (profile fields + the first-login
    //   flags; all privileged fields stay frozen).
    // Branch members: read users in their OWN branch — their team (managers their
    //   team; employees their shift coworkers + manager, resolved from the weekly
    //   schedule's uids). Read-only — only an admin writes accounts.
    // Admin: read/write everything — role, branch, (de)activation, position,
    //   employment status, password-reset flag.
    match /users/{uid} {
      allow read: if isOwner(uid)
        || isAdmin()
        || (selfBranch() != ''
            && resource.data.get('branchId', '') == selfBranch());

      // No client may create a user document — the only creation path is the
      // admin-only `createUserAccount` Cloud Function (Admin SDK).
      allow create: if false;

      // Admin: full control.
      // Self: profile fields + the first-login flags (mustChangePassword,
      //   isProfileCompleted, hasCompletedOnboarding — the one-time Welcome
      //   flag) + non-privileged fields (fcmToken, and paymentNumber — the
      //   employee's own salary-receiving number). All PRIVILEGED fields (below)
      //   stay frozen — the flags above are permitted precisely because they are
      //   NOT in that freeze-list: role, isActive, branchId,
      //   assignedShift, position, employmentStatus, createdBy, and the
      //   admin-set compensation fields (salaryAmount, salaryType,
      //   paymentMethod).
      // Managers do NOT write user docs (they manage branch operations only).
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.get('role', 'employee')
                 == resource.data.get('role', 'employee')
            && request.resource.data.get('isActive', true)
                 == resource.data.get('isActive', true)
            && request.resource.data.get('branchId', '')
                 == resource.data.get('branchId', '')
            && request.resource.data.get('assignedShift', '')
                 == resource.data.get('assignedShift', '')
            && request.resource.data.get('position', '')
                 == resource.data.get('position', '')
            && request.resource.data.get('employmentStatus', 'active')
                 == resource.data.get('employmentStatus', 'active')
            && request.resource.data.get('createdBy', '')
                 == resource.data.get('createdBy', '')
            && request.resource.data.get('salaryAmount', 0)
                 == resource.data.get('salaryAmount', 0)
            && request.resource.data.get('salaryType', '')
                 == resource.data.get('salaryType', '')
            && request.resource.data.get('paymentMethod', '')
                 == resource.data.get('paymentMethod', ''));

      // Deactivate via isActive (an admin update), never a hard delete; document
      // cleanup on account removal belongs to a Cloud Function.
      allow delete: if false;

      // ── Private compensation (C2 fix, 2026-07-03) ────────────────
      // Salary data lives OFF the branch-readable user doc, in
      // users/{uid}/private/compensation — Firestore reads are document-level
      // (no field filtering), so anything on the parent doc is served whole
      // to every same-branch member. Here only the OWNER and an ADMIN read;
      // managers deliberately cannot (compensation is admin-managed — branch
      // reach must never expose pay). The owner may create/update ONLY their
      // own `paymentNumber` (their salary-receiving number, exposed in Edit
      // Profile); the admin-set fields are admin-only. No client deletes.
      match /private/{docId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isAdmin()
          || (isOwner(uid) && docId == 'compensation'
              && request.resource.data.keys().hasOnly(['paymentNumber']));
        allow update: if isAdmin()
          || (isOwner(uid) && docId == 'compensation'
              && request.resource.data.diff(resource.data)
                   .affectedKeys().hasOnly(['paymentNumber']));
        allow delete: if false;
      }
    }

    // ── Tasks (Phase 3, +Phase 9 multi-assignee) ───────────────────
    // Branch-scoped: admin = all branches; manager = own branch; employee =
    // tasks they're assigned to. A task carries `branchId` (owning branch) and
    // `assigneeIds` (the assignees — Phase 9; `assignedEmployeeId` mirrors the
    // primary assignee for backward compatibility).
    //   read   — admin/own-branch manager, OR any assigned employee.
    //   create/delete — admin/own-branch manager only.
    //   update — admin/own-branch manager (full edit, incl. approve/reject), OR
    //            an assigned employee on a task they're assigned to, with limits:
    //            they may NOT reassign (assigneeIds frozen), move branch, change
    //            the creator, or set the terminal approved/rejected status
    //            (review stays manager/admin). They MAY tick checklist items,
    //            add notes/proof, and advance status up to waitingReview.
    function isTaskAssignee() {
      return request.auth.uid in resource.data.get('assigneeIds', [])
        || resource.data.get('assignedEmployeeId', '') == request.auth.uid;
    }
    // Shift Assignment feature: a task with assignmentType 'shift' targets
    // whoever's rostered on its shift, not a named assignee (assigneeIds is
    // always empty), so it can't be reached via isTaskAssignee(). Trust is
    // branch-scoped (any employee in the task's branch), same bounded fields
    // as isTaskAssignee() below — the UI only ever shows the action to someone
    // actually on that shift today; the client-side `canUserAccessTask` check
    // is what hides it from everyone else.
    function isShiftTaskInMyBranch() {
      return resource.data.get('assignmentType', 'individual') == 'shift'
        && selfBranch() != ''
        && resource.data.get('branchId', '') == selfBranch();
    }
    match /tasks/{taskId} {
      allow read: if canReachBranch(resource.data.get('branchId', ''))
        || isTaskAssignee()
        || isShiftTaskInMyBranch();

      allow create: if canReachBranch(request.resource.data.get('branchId', ''));

      // An APPROVED task is a locked, reviewed record. A manager/admin may not
      // edit / reassign / re-status it in place; the ONLY change permitted on an
      // already-approved task is an ADMIN REOPEN — moving it OUT of `approved`
      // (back into the workflow) so a mistaken approval is recoverable. The
      // review transition INTO approved is unaffected (the stored status is then
      // `waitingReview`, so this guard passes).
      allow update: if (canReachBranch(resource.data.get('branchId', ''))
            && (resource.data.get('status', 'pending') != 'approved'
                || (isAdmin()
                    && request.resource.data.get('status', 'pending') != 'approved')))
        || ((isTaskAssignee() || isShiftTaskInMyBranch())
            // employees can't reassign the task (assignees frozen)
            && request.resource.data.get('assigneeIds', [])
                 == resource.data.get('assigneeIds', [])
            && request.resource.data.get('branchId', '')
                 == resource.data.get('branchId', '')
            && request.resource.data.get('createdBy', '')
                 == resource.data.get('createdBy', '')
            && request.resource.data.get('status', 'pending') != 'approved'
            && request.resource.data.get('status', 'pending') != 'rejected'
            // employees can't forge review attribution…
            && request.resource.data.get('approvedBy', '')
                 == resource.data.get('approvedBy', '')
            && request.resource.data.get('rejectedBy', '')
                 == resource.data.get('rejectedBy', '')
            // …nor the rest of the review record (P1-5): the reviewer's notes,
            // the rework counter, and the review timestamps are manager/admin
            // territory. An employee's legitimate writes (start / submit / tick a
            // checklist item / add proof) never touch these, so freezing them
            // costs nothing and stops a crafted client rewriting the verdict.
            && request.resource.data.get('reviewNotes', '')
                 == resource.data.get('reviewNotes', '')
            && request.resource.data.get('rejectionReason', '')
                 == resource.data.get('rejectionReason', '')
            && request.resource.data.get('revisionNumber', 0)
                 == resource.data.get('revisionNumber', 0)
            && request.resource.data.get('approvedAt', null)
                 == resource.data.get('approvedAt', null)
            && request.resource.data.get('rejectedAt', null)
                 == resource.data.get('rejectedAt', null)
            // The activity log is append-only history: an employee may GROW it
            // (start / submit append entries) but never shrink or rewrite it, so
            // a manager's past rejection note can't be deleted. Size-only check —
            // rules can't diff array contents, but preventing shrink closes the
            // "erase history" path; entry contents stay observable in the log.
            && request.resource.data.get('activityLog', []).size()
                 >= resource.data.get('activityLog', []).size());

      // Approved tasks can't be deleted either (reopen first). Matches the lock
      // above so a reviewed record can't be silently removed.
      allow delete: if canReachBranch(resource.data.get('branchId', ''))
        && resource.data.get('status', 'pending') != 'approved';
    }

    // ── Task templates (stabilization) ─────────────────────────────
    // Reusable task blueprints ("Open Shop", "Night Checklist", …) managed by
    // managers/admins. A template carries a `branchId` (owning branch) or '' for
    // a GLOBAL template (admin-made, usable by every branch). Employees never
    // need templates.
    //   read   — any admin or manager (branch filtering is applied client-side;
    //            the collection is tiny, so a full read is acceptable and a
    //            collection query stays provably safe under this rule).
    //   create — admin (any branch / global), OR an own-branch manager.
    //   update/delete — admin, OR the owning-branch manager.
    match /task_templates/{templateId} {
      allow read: if isAdmin() || isManager();
      allow create: if isAdmin()
        || (isManager()
            && request.resource.data.get('branchId', '') == selfBranch());
      allow update, delete: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());
    }

    // ── Recurring shift-task templates (Shift Assignment feature) ──
    // Permanent blueprints for a shift-assigned task that repeats on its own
    // clock (e.g. "Open Store" every day on the Morning shift), read by the
    // `generateShiftTaskInstances` Cloud Function (Admin SDK — bypasses these
    // rules). Always branch-scoped (a shift only means something within one
    // branch's roster) — no global option, unlike `task_templates`.
    match /recurringTaskTemplates/{templateId} {
      allow read: if isAdmin() || isManager();
      allow create: if isAdmin()
        || (isManager()
            && request.resource.data.get('branchId', '') == selfBranch());
      allow update, delete: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());
    }

    // ── Branches (Phase 5) ─────────────────────────────────────────
    // Any signed-in user may READ branches (names are shown in pickers and on
    // cards across roles). Only an admin may create/edit. "Delete" is a soft
    // delete (an admin update setting `deletedAt`), so hard deletes are denied.
    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // ── Weekly schedules (Phase 7) ─────────────────────────────────
    // The in-app weekly roster, one doc per (branch, week). Branch-scoped:
    //   read   — admin/own-branch manager, OR any employee of that branch (so
    //            they can see their own schedule + today's team).
    //   write  — admin/own-branch manager only (employees never edit; swaps are
    //            applied by the manager on approval).
    match /weekly_schedules/{scheduleId} {
      // `resource == null` first: a `get()` on a not-yet-created week's doc must
      // return an empty snapshot (no schedule), not a permission error — the app
      // reads a deterministic week id that often doesn't exist yet. For existing
      // docs, scope by branch (admin/own-branch manager, or any branch employee).
      allow read: if resource == null
        || canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('branchId', '') == selfBranch();
      allow create: if canReachBranch(request.resource.data.get('branchId', ''));
      allow update, delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Shift templates (Schedule V2 · Pillar 5) ───────────────────
    // Reusable per-branch shift hours (`{branch}__{role}`). Managed by the
    // branch's manager (and admin); readable by any branch member so hour
    // displays resolve. Mirrors `weekly_schedules` scoping exactly.
    match /shift_templates/{templateId} {
      allow read: if resource == null
        || canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('branchId', '') == selfBranch();
      allow create: if canReachBranch(request.resource.data.get('branchId', ''));
      allow update, delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Shift swaps (Phase 7) ──────────────────────────────────────
    // A swap request between two employees, approved by the branch manager.
    //   read   — admin/own-branch manager, OR the requester/target employee.
    //   create — the requester themself, for a swap in their own branch, only for
    //            an UPCOMING shift (past/in-progress shifts can't be swapped —
    //            spec §2; the precise rule also lives client-side in
    //            SwapEligibility, this is the server backstop).
    //   update — admin/own-branch manager (reject), OR either involved employee
    //            (coworker approve / requester cancel / decline). The exact status
    //            flow is validated client-side (ShiftSwapCubit). The FINAL
    //            approval (status → managerApproved) is **denied to all clients**
    //            and applied only by the `approveSwap` Cloud Function (Admin SDK),
    //            which re-validates and rewrites the schedule atomically.
    //   delete — admin/own-branch manager only.

    // Day offset within the week (Sunday=0 … Saturday=6), matching ScheduleDay.
    function swapDayOffset(d) {
      return d == 'monday' ? 1
        : d == 'tuesday' ? 2
        : d == 'wednesday' ? 3
        : d == 'thursday' ? 4
        : d == 'friday' ? 5
        : d == 'saturday' ? 6
        : 0; // sunday / unknown
    }
    // Shift start, minutes past midnight (mirrors SwapEligibility / timeRange):
    // morning 08:30, night 16:30.
    function swapShiftMinutes(s) {
      return s == 'night' ? (16 * 60 + 30) : (8 * 60 + 30);
    }
    // The slot's start instant must be strictly after the request time. weekStart
    // is the week's Sunday 00:00 (a Timestamp).
    function swapSlotInFuture(data) {
      return data.weekStart
          + duration.value(swapDayOffset(data.get('day', 'sunday')), 'd')
          + duration.value(swapShiftMinutes(data.get('shift', 'morning')), 'm')
        > request.time;
    }
    match /shift_swaps/{swapId} {
      allow read: if canReachBranch(resource.data.get('branchId', ''))
        || resource.data.get('requesterId', '') == request.auth.uid
        || resource.data.get('targetId', '') == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.get('requesterId', '') == request.auth.uid
        && request.resource.data.get('branchId', '') == selfBranch()
        && swapSlotInFuture(request.resource.data);
      // M1 fix (2026-07-03): per-party STATUS-TRANSITION enforcement. The old
      // rule let either involved employee set any non-final status — so a
      // requester could forge the coworker-acceptance step (employeeApproved)
      // and deceive the manager into approving a trade the coworker never
      // agreed to. Now:
      //   manager/admin — anything except managerApproved (finalizing is
      //     OWNED BY the approveSwap Cloud Function: Admin SDK, bypasses
      //     rules, re-validates + applies the exchange atomically).
      //   TARGET  — consents/declines a PENDING request only
      //     (pending → employeeApproved | rejected).
      //   REQUESTER — withdraws their own unresolved request only
      //     (pending | employeeApproved → cancelled). They can NEVER set
      //     employeeApproved.
      //   Employee writes are field-locked to status (+ updatedAt) — no
      //   editing day/shift/target/branch after creation.
      allow update: if (canReachBranch(resource.data.get('branchId', ''))
          && request.resource.data.get('status', '') != 'managerApproved')
        || (isSignedIn()
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['status', 'updatedAt'])
            && (
              (request.auth.uid == resource.data.get('targetId', '')
                && resource.data.get('status', '') == 'pending'
                && request.resource.data.get('status', '')
                     in ['employeeApproved', 'rejected'])
              || (request.auth.uid == resource.data.get('requesterId', '')
                && resource.data.get('status', '')
                     in ['pending', 'employeeApproved']
                && request.resource.data.get('status', '') == 'cancelled')
            ));
      allow delete: if canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Broadcasts (Communications Center — Phase 1 + Phase 2 engine) ──
    // A one-way announcement to every branch, a single branch, or one individual.
    // The targeting dimension for the branch/all feed is `branchId`: a branch id
    // scopes it to that branch; the empty string '' means ALL branches. A direct
    // message to one user carries `targetUserId` + a non-branch `branchId` marker
    // ('__direct__'), so it never surfaces in a branch/all feed.
    //
    //   read   — admin (all), OR the individual recipient (`targetUserId`), OR a
    //            branch member of a branch/all-branches broadcast (a non-DM doc
    //            whose branchId is '' or their own branch). A branch member's
    //            `whereIn: [selfBranch, '']` query is provably safe under this.
    //   write  — OWNED BY THE `sendBroadcast` Cloud Function (Admin SDK, which
    //            bypasses these rules). Clients never write broadcast docs
    //            directly — the function validates sender permissions, resolves
    //            recipients, persists the doc, and pushes the notification.
    match /broadcasts/{broadcastId} {
      allow read: if isAdmin()
        || resource.data.get('targetUserId', '') == request.auth.uid
        || request.auth.uid in resource.data.get('targetUserIds', [])
        || (resource.data.get('targetUserId', '') == ''
            && resource.data.get('targetUserIds', []).size() == 0
            && (resource.data.get('branchId', '') == ''
                || resource.data.get('branchId', '') == selfBranch()));

      // Content + delivery stats are owned by the `sendBroadcast` Cloud Function
      // (Admin SDK, bypasses rules). Clients may flip ONLY `archivedAt` (archive
      // / unarchive) — and only an admin, the owning-branch manager, or the
      // original sender. The field-diff freezes every other field, so delivery
      // stats / recipients can never be forged client-side.
      allow update: if request.resource.data
              .diff(resource.data).affectedKeys()
              .hasOnly(['archivedAt'])
        && (isAdmin()
            || resource.data.get('senderId', '') == request.auth.uid
            || canReachBranch(resource.data.get('branchId', '')));

      allow create: if false;

      // Delete (permanent) — the original sender, an admin, or the owning-branch
      // manager may remove a broadcast from the feed. (Content/stats are still
      // function-owned; this just removes the whole doc, it can't forge fields.)
      allow delete: if isAdmin()
        || resource.data.get('senderId', '') == request.auth.uid
        || canReachBranch(resource.data.get('branchId', ''));
    }

    // ── Broadcast templates (Communications Center — Phase 2 Commit 2) ──
    // Reusable broadcast blueprints (mirrors `task_templates`). A template
    // carries a `branchId` (owning branch) or '' for a GLOBAL template
    // (admin-made, usable by every branch). Employees never need templates.
    //   read   — any admin or manager (branch filtering is client-side).
    //   create — admin (any/global), OR an own-branch manager.
    //   update/delete — admin, OR the owning-branch manager.
    match /broadcastTemplates/{templateId} {
      allow read: if isAdmin() || isManager();
      allow create: if isAdmin()
        || (isManager()
            && request.resource.data.get('branchId', '') == selfBranch());
      allow update, delete: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());
    }

    // ── Broadcast schedules (Communications Center — Phase 2 Commit 4) ──
    // Scheduled / recurring broadcasts. The `runBroadcastSchedules` Cloud
    // Function fires + advances them via the Admin SDK (bypasses these rules);
    // clients only manage their own.
    //   read   — admin, OR the creator (`senderId`).
    //   create — the creator themself; a manager only for their own branch.
    //   update/delete — admin, OR the creator (pause/resume/edit/cancel).
    match /broadcastSchedules/{scheduleId} {
      allow read: if isAdmin()
        || resource.data.get('senderId', '') == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.get('senderId', '') == request.auth.uid
        && (isAdmin()
            || (isManager()
                && (request.resource.data.get('branchId', '') == selfBranch()
                    || request.resource.data.get('branchId', '') == '')));
      allow update, delete: if isAdmin()
        || resource.data.get('senderId', '') == request.auth.uid;
    }

    // ── Task reminders ledger (Communications Center — Phase 2 Commit 5) ──
    // Per-task anti-spam bookkeeping written ONLY by the `runTaskReminders` Cloud
    // Function (Admin SDK, bypasses rules). Clients never write it; an admin may
    // read it for diagnostics.
    match /taskReminders/{taskId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── Reminder config (Communications Center — Phase 2 Commit 5) ──
    // Org-wide reminder rules (enabled · quiet hours · max reminders), read by the
    // scheduler. Admin-managed; any admin/manager may read.
    match /reminderConfig/{id} {
      allow read: if isAdmin() || isManager();
      allow write: if isAdmin();
    }

    // ── Notifications (Notification System Phase 1 + M2 fix 2026-07-03) ──
    // One in-app notification doc per recipient (`notifications/{id}`).
    //   read   — the recipient, or an admin.
    //   create — CLIENTS NEVER CREATE DIRECTLY (M2 fix). Every client-produced
    //            notification goes through the `sendNotification` callable
    //            (type whitelist · branch-scoped recipients · length caps ·
    //            server-stamped senderUid); broadcasts/reminders come from
    //            their own functions. All writes are Admin SDK (bypass rules).
    //   update — the recipient only (mark read flips `readAt`); content is not
    //            re-validated, but only the owner can touch their own docs.
    //   delete — the recipient, or an admin (dismiss / cleanup).
    match /notifications/{id} {
      allow read: if isOwner(resource.data.get('recipientUid', '')) || isAdmin();
      allow create: if false;
      allow update: if isOwner(resource.data.get('recipientUid', ''));
      allow delete: if isOwner(resource.data.get('recipientUid', '')) || isAdmin();
    }

    // ── Case Management (private conversation until resolution) ────
    // A branch-scoped internal case — a private conversation between a reporter
    // (employee/manager) and a recipient (manager/admin). The case doc is
    // readable by the branch manager (only when routed to them —
    // `visibleToManager`), any admin, and the reporter — and it deliberately
    // carries NO creator uid. The reporter's identity is isolated in the private
    // `reporter/identity` subdoc below (owner + admin only), so a same-branch
    // manager can never resolve a confidential sender from the case itself. The
    // conversation lives in the `messages` subcollection.
    //   read   — admin (all) · own-branch manager (visibleToManager only) ·
    //            the reporter (via the identity subdoc).
    //   create — any branch member, for a case in their OWN branch (admin: any).
    //   update — admin / own-branch manager drive the STATUS only. The reporter
    //            interacts via `messages`, never the case doc; `lastMessage*`
    //            bumps come from the Admin SDK, which bypasses these rules.
    //   delete — admin only (cases are records).
    match /cases/{caseId} {
      allow read: if isAdmin()
        || (isManager()
            && resource.data.get('branchId', '') == selfBranch()
            && resource.data.get('visibleToManager', true) == true)
        || isCaseReporter(caseId);

      allow create: if isAdmin()
        || (isSignedIn()
            && request.resource.data.get('branchId', '') == selfBranch());

      allow update: if isAdmin()
        || (isManager()
            && resource.data.get('branchId', '') == selfBranch()
            && resource.data.get('visibleToManager', true) == true);

      allow delete: if isAdmin();

      // ── Conversation messages (`cases/{id}/messages/{id}`) ─────────
      //   read   — anyone who can read the parent case.
      //   create — a participant, a `message` (opening/system are Admin-SDK-only,
      //            so clients can't forge them), only while the case is NOT closed
      //            (read-only when closed), stamping themselves as author (a
      //            de-identified confidential reporter writes authorId == '').
      //   update/delete — never (messages are an immutable record).
      match /messages/{messageId} {
        allow read: if isAdmin()
          || (isManager()
              && caseData(caseId).get('branchId', '') == selfBranch()
              && caseData(caseId).get('visibleToManager', true) == true)
          || isCaseReporter(caseId);

        allow create: if request.resource.data.get('kind', 'message') == 'message'
          && caseData(caseId).get('status', 'open') != 'closed'
          && request.resource.data.get('createdAt', request.time) == request.time
          && (
               isAdmin()
               || (isManager()
                   && caseData(caseId).get('branchId', '') == selfBranch()
                   && caseData(caseId).get('visibleToManager', true) == true
                   && request.resource.data.get('authorId', '') == request.auth.uid)
               || (isCaseReporter(caseId)
                   && (request.resource.data.get('authorId', '') == request.auth.uid
                       || request.resource.data.get('authorId', '') == ''))
             );

        allow update, delete: if false;
      }
    }

    // ── Private reporter identity (COLLECTION-GROUP rule) ─────────────
    // `cases/{id}/reporter/identity` holds the creator uid/name. This MUST be a
    // collection-group rule (the recursive `{path=**}` wildcard): a nested
    // `match /cases/{id}/reporter/{doc}` rule secures direct-path reads but does
    // NOT authorize the owner's `collectionGroup('reporter')` "My Cases" query —
    // documented Firestore behavior, so that query returns permission-denied even
    // with the index present. Read: the reporter (own list + admin reveal) + an
    // admin ONLY — never a manager (keeps confidential senders hidden); the query
    // is proven safe by the createdByUserId equality. Created once with the case
    // (self-claim); immutable thereafter. `reporter` exists only under `cases/`,
    // so the wildcard can't leak to another collection.
    match /{path=**}/reporter/{docId} {
      allow read: if isAdmin()
        || resource.data.get('createdByUserId', '') == request.auth.uid;
      allow create: if isSignedIn()
        && docId == 'identity'
        && request.resource.data.get('createdByUserId', '') == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Operations Requests (in-the-moment approvals) ─────────────
    // A branch-scoped operational approval an employee needs during the day
    // (leave the store, staff discount, gift, stock, maintenance…). Unlike a
    // Case there is NO privacy split — the requester's uid rides the doc.
    //   read   — admin (all) · own-branch manager · the requester.
    //   create — any branch member, for a request in their OWN branch (admin:
    //            any), stamping themselves as requester with status 'pending'.
    //   update — admin (anything) · own-branch manager. The decision is just
    //            approve/reject. `refCode`/`lastEvent*` bumps come from the Admin
    //            SDK (onRequest* functions), which bypasses these rules.
    //   delete — admin only (requests are records).
    match /requests/{requestId} {
      allow read: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch())
        || isOwner(resource.data.get('requesterId', ''));

      allow create: if isSignedIn()
        && request.resource.data.get('requesterId', '') == request.auth.uid
        && request.resource.data.get('status', 'pending') == 'pending'
        && (isAdmin()
            || request.resource.data.get('branchId', '') == selfBranch());

      allow update: if
        isAdmin()
        || (isManager()
            && resource.data.get('branchId', '') == selfBranch());

      allow delete: if isAdmin();

      // ── Timeline events (`requests/{id}/events/{id}`) ──────────────
      //   read   — anyone who can read the parent request.
      //   create — a participant posts a `comment`/`attachmentAdded`, stamping
      //            themselves as author, only while the request is still active
      //            (pending/approved). The `submitted` + lifecycle events are
      //            Admin-SDK-only, so clients can't forge them.
      //   update/delete — never (events are an immutable record).
      match /events/{eventId} {
        allow read: if isAdmin()
          || (isManager()
              && requestData(requestId).get('branchId', '') == selfBranch())
          || isOwner(requestData(requestId).get('requesterId', ''));

        allow create:
          if (request.resource.data.get('kind', 'comment') == 'comment'
              || request.resource.data.get('kind', 'comment') == 'attachmentAdded')
          && request.resource.data.get('createdAt', request.time) == request.time
          && request.resource.data.get('authorId', '') == request.auth.uid
          && requestData(requestId).get('status', 'pending') == 'pending'
          && (
               isAdmin()
               || (isManager()
                   && requestData(requestId).get('branchId', '') == selfBranch())
               || isOwner(requestData(requestId).get('requesterId', ''))
             );

        allow update, delete: if false;
      }
    }

    // ── Community Hub / DROP Events (`events/{eventId}`) ───────────
    // Each event is a single self-contained document with every workspace
    // section (timeline / team / tasks / inventory / logistics / budget /
    // communication / outcome) embedded inline, so a section edit is one
    // whole-document update — governed by a single update rule.
    //   read   — admin (all) · a branch member (manager OR employee) whose
    //            branch matches the event. A null-branch event is admin-only.
    //   create — admin (any branch) · manager (own branch only), stamping
    //            themselves as `createdBy`.
    //   update — admin (anything) · own-branch manager. Covers every section
    //            edit, status change, and the soft-delete (`deletedAt`) stamp.
    //   delete — never (events are records; removal is a soft-delete update).
    match /events/{eventId} {
      allow read: if isAdmin()
        || (selfBranch() != ''
            && resource.data.get('branchId', '') == selfBranch());

      allow create: if isSignedIn()
        && request.resource.data.get('createdBy', '') == request.auth.uid
        && (isAdmin()
            || (isManager()
                && request.resource.data.get('branchId', '') == selfBranch()));

      allow update: if isAdmin()
        || (isManager()
            && resource.data.get('branchId', '') == selfBranch());

      allow delete: if false;
    }

    // ── Monotonic counters (`counters/{id}`) ──────────────────────
    // e.g. `counters/requests` backs the human-friendly REQ-000123 sequence,
    // written ONLY by the Admin SDK (the `onRequestCreated` transaction), which
    // bypasses these rules. Clients never touch it.
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // ── Feed usage telemetry (Home Dashboard redesign) ──
    // A single aggregate counters doc (`usageStats/feed`) of
    // `FieldValue.increment` fields — preset/sort/expansion/approve/note usage.
    // Any signed-in user may increment (trusted internal telemetry, no PII);
    // only an admin reads the totals. Debounced client-side to ~one write/20s.
    match /usageStats/{doc} {
      allow read: if isAdmin();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // ── Audit log (immutable Event Tracking trail) ─────────────────
    // One append-only record per important business action, written through the
    // `EventTrackingService` (never by a feature directly). An entry is a fact
    // about the past, so it is IMMUTABLE: created once, never edited, never hard
    // deleted. The only mutation is an ADMIN SOFT DELETE (flip
    // isDeleted/deletedAt/deletedBy and nothing else) — the record is retained,
    // just hidden from normal reads.
    //   read   — admin (all) · own-branch manager (their branch's history). An
    //            employee has no audit-read need (auditing is a management tool).
    //   create — any signed-in user may append an event AS THEMSELVES. `actorId`
    //            is pinned to the caller so a client can NEVER forge another
    //            user's history; the record must be born live (isDeleted false)
    //            with a valid schemaVersion. `timestamp` is a server timestamp.
    //   update — admin only, and ONLY the soft-delete field diff.
    //   delete — never (no hard delete anywhere in the stack).
    match /audit_logs/{id} {
      allow read: if isAdmin()
        || (isManager() && resource.data.get('branchId', '') == selfBranch());

      allow create: if isSignedIn()
        && request.resource.data.get('actorId', '') == request.auth.uid
        && request.resource.data.get('isDeleted', false) == false
        && request.resource.data.get('schemaVersion', 0) is int
        && request.resource.data.get('schemaVersion', 0) >= 1;

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['isDeleted', 'deletedAt', 'deletedBy'])
        && request.resource.data.get('isDeleted', false) == true;

      allow delete: if false;
    }
  }
}
